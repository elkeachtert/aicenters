{
  "ssg": "hugo",
  "mode": "hosted",
  "build_configuration": {
    "install_command": "[ -f package.json ] && npm i",
    "destination": "public",
    "baseURL": "/",
    "noTimes": true,
    "hugoVersion": "0.160.2",
    "rubyVersion": "4.0.1",
    "nodeVersion": "24",
    "denoVersion": "1.40.2",
    "environment_variables": [
      {
        "key": "HUGO_CACHEDIR",
        "value": "/usr/local/__site/src/.hugo_cache/"
      }
    ],
    "preserved_paths": "node_modules/,.hugo_cache/,resources/",
    "environment": "",
    "source": "",
    "config": "",
    "configDir": "",
    "contentDir": "",
    "layoutDir": "",
    "themesDir": "",
    "theme": "",
    "logFile": "",
    "logLevel": "",
    "ignoreVendorPaths": "",
    "disableKinds": "",
    "buildDrafts": false,
    "buildExpired": false,
    "buildFuture": false,
    "cleanDestinationDir": false,
    "debug": false,
    "enableGitInfo": false,
    "gc": false,
    "i18nWarnings": false,
    "ignoreCache": false,
    "ignoreVendor": false,
    "log": false,
    "minify": false,
    "noChmod": false,
    "pathWarnings": false,
    "mem": false,
    "quiet": false,
    "templateMetrics": false,
    "templateMetricsHints": false,
    "verbose": false,
    "verboseLog": false,
    "preserveOutput": false,
    "includeGit": false,
    "use_beta_plugin": false
  }
}