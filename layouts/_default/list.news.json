[ {{- $i := 0 -}}

{{ range sort (where site.RegularPages "Section" "news") ".Date" "desc" -}}
  {{- if gt $i 0 }},{{ end }}
  {
	"id":"{{ add $i 1 }}",
	"permalink":"{{ .Permalink }}", 
	"date":"{{ .Date.Unix }}", 
	"title":{{ .Title | jsonify  }}, 
	"subtitle":{{ .Params.subtitle | jsonify  }}, 
	"img":"{{ .Params.img }}", 
	"copyright":"{{ .Params.copyright }}",
	"content":{{ .Content | jsonify }},
	"teaser":{{ .Params.teaser | jsonify }},
	"description":{{ .Params.description | jsonify }}
}
  {{- $i = add $i 1 -}}
{{ end -}}

]


