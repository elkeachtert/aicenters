[ {{- $i := 0 -}}
{{ $section := .Page.Section}}
{{ range $.Site.Data.sw -}}
	{{ range .switem -}}
        {{- if gt $i 0 }},{{ end }}
        {
			"id":"{{ .no }}", 
			"url":"{{ .Permalink }}", 
			"title":{{ .title | jsonify  }}, 
			"author":"{{ .author }}", 
			"journal":"{{ .journal }}",
			"link":"{{ .link }}",
			"linktext":"{{ .linktext }}",
			"link2":"{{ .link2 }}",
			"linktext2":"{{ .linktext2 }}",
			"section": {{ .Section | jsonify -}} 
		}
        {{- $i = add $i 1 -}}
	{{- end -}}
{{- end -}} ]


